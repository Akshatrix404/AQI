# ─────────────────────────────────────────────────────────────────
# AtmosWatch — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────────

# 1. WAQI (World Air Quality Index) Token — FREE, instant
#    Get at: https://aqicn.org/data-platform/token/
#    Used for: Real-time AQI data, city search, global map tiles
VITE_WAQI_TOKEN=your_waqi_token_here

# 2. OpenWeatherMap API Key — FREE (1,000 calls/day)
#    Get at: https://openweathermap.org/api → "Current Weather Data" (free)
#    Used for: Weather data, wind direction, temperature, humidity
VITE_OWM_KEY=your_openweathermap_key_here

# 3. Anthropic API Key — FREE $5 credit on signup
#    Get at: https://console.anthropic.com/
#    Used for: AI physiological explanations, training plan rescheduling,
#              country pollution analysis, AQI coaching chat
VITE_ANTHROPIC_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────────────────────────
# These APIs require NO KEY (completely free, no signup):
# • Open-Meteo       — air quality + weather forecast
# • OSRM             — route calculation
# • Overpass API     — OpenStreetMap paths
# • Open-Elevation   — elevation data
# • Nominatim        — reverse geocoding
# ─────────────────────────────────────────────────────────────────
